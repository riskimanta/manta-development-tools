# SQLite (development)
DATABASE_URL="file:./dev.db"

# Postgres example (production)
# DATABASE_URL="postgresql://user:password@localhost:5432/mandev?schema=public"

# Optional password gate for the whole app (leave empty to disable).
# When MANDEV_PASSWORD is set, you must also set MANDEV_AUTH_SECRET (min 16 chars)
# used to sign the session cookie (JWT).
# MANDEV_PASSWORD=
# MANDEV_AUTH_SECRET=

# Optional local command execution for saved run profiles (local-only; keep false
# if ManDev is exposed on a network).
# MANDEV_ENABLE_COMMAND_EXECUTION=false

# Local agent token for `mandev track` CLI capture (required for POST /api/work-progress/capture).
# MANDEV_AGENT_TOKEN=
