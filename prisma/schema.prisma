generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum FeatureStatus {
  draft
  ready
  in_progress
  done
}

model Project {
  id           String                @id @default(cuid())
  name         String
  slug         String                @unique
  description  String?
  repoUrl      String?
  localPath    String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  features     Feature[]
  architecture ProjectArchitecture?
  runProfiles  ProjectRunProfile[]
  workProgressEntries WorkProgress[]
  workProgressSessionSummaries WorkProgressSessionSummary[]

  @@index([updatedAt])
}

model ProjectRunProfile {
  id               String   @id @default(cuid())
  projectId        String
  name             String
  command          String
  workingDirectory String?
  description      String?
  isDefault        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  project Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  runs    ProjectRunProfileRun[]

  @@index([projectId])
  @@index([projectId, isDefault])
}

model ProjectRunProfileRun {
  id               String    @id @default(cuid())
  runProfileId     String
  status           String
  command          String
  workingDirectory String
  pid              Int?
  startedAt        DateTime
  endedAt          DateTime?
  exitCode         Int?
  signal           String?
  durationMs       Int?
  stdoutPreview    String?
  stderrPreview    String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  runProfile ProjectRunProfile @relation(fields: [runProfileId], references: [id], onDelete: Cascade)

  @@index([runProfileId])
  @@index([startedAt])
  @@index([runProfileId, startedAt])
}

model ProjectArchitecture {
  id            String   @id @default(cuid())
  projectId     String   @unique
  summary       String?
  mermaidSource String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([updatedAt])
}

model Feature {
  id          String         @id @default(cuid())
  projectId   String
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      FeatureStatus  @default(draft)
  priority    Int?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([projectId])
  @@index([status])
}

model WorkProgress {
  id                  String   @id @default(cuid())
  projectId           String
  branch              String
  latestCommitHash    String
  latestCommitMessage String
  latestCommitAuthor  String
  latestCommitDate    DateTime
  changedFilesJson    String
  changedFilesCount   Int
  gitStatusText       String
  summary             String
  note                String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([projectId, createdAt])
}

model WorkProgressSessionSummary {
  id String @id @default(cuid())

  projectId String
  sessionId String

  summaryMarkdown String

  firstSnapshotId String?
  latestSnapshotId String?
  branch String?
  sessionStartedAt DateTime?
  sessionEndedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, sessionId])
  @@index([projectId])
}
